# Base URL of the Leadsrack API (no trailing slash).
#
# Local dev (api on host):     http://localhost:4000/api
# Local dev (docker compose):  /api      (nginx proxies to the api service)
# Production (Vercel):         https://<your-render-service>.onrender.com/api
#
# In Vercel, set this in Project Settings → Environment Variables.
VITE_API_URL=http://localhost:4000/api
