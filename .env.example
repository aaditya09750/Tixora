# Compose-level env vars. Copy this file to `.env` and fill the values
# before running `docker compose up`.

# REQUIRED. Minimum 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Optional. JWT lifetime — accepts "7d", "12h", "30m", or seconds as a number.
JWT_EXPIRES_IN=7d

# Optional. Allowed CORS origins for the API (comma-separated).
CORS_ORIGIN=http://localhost:8080

# Optional. fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Optional. bcrypt cost factor (10 dev / 12+ prod).
BCRYPT_ROUNDS=10

# Host-side port mappings.
WEB_PORT=8080
API_PORT=4000
MONGO_PORT=27017
